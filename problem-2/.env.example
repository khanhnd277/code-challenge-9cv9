# Application
NODE_ENV=development
PORT=3000

# Logging
# Levels: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
# This file is a template. Copy it to .env before making any changes:
#   cp .env.example .env
#
# Option A — PostgreSQL (production)
#   1. In your .env, uncomment DATABASE_URL and fill in your credentials.
#   2. Comment out or remove DATABASE_PATH in your .env.
#   3. Apply the schema:
#        npm run db:push              (quick, no migration files)
#        npm run db:generate          (generate migration SQL files first)
#        npm run db:migrate           (then apply them)
# DATABASE_URL=postgres://user:password@localhost:5432/mydb

# Option B — SQLite (development / default)
#   Leave DATABASE_URL commented out; DATABASE_PATH points to the DB file.
#   Tests automatically override this with ":memory:" — no action needed.
DATABASE_PATH=./data.db

# SQLite only — how long (ms) to wait when the DB file is locked by another process
DB_BUSY_TIMEOUT_MS=5000
